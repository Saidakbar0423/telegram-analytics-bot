# ============= TELEGRAM CREDENTIALS =============
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_user_id_here

# ============= DATABASE =============
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/telegram_analytics
DB_USER=user
DB_PASSWORD=password
DB_NAME=telegram_analytics
DB_HOST=postgres
DB_PORT=5432

# ============= REDIS =============
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============= JWT AUTHENTICATION =============
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============= PARSER SETTINGS =============
PARSER_BATCH_SIZE=100
PARSER_INTERVAL_SECONDS=300
MAX_FLOOD_WAIT_SECONDS=60
PARSER_ENABLED=true

# ============= API SETTINGS =============
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============= LOGGING =============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ============= ENVIRONMENT =============
ENVIRONMENT=development
DEBUG=true

# ============= TELEGRAM GROUPS/CHANNELS TO MONITOR =============
MONITORED_GROUPS=@testgroup1,@testgroup2